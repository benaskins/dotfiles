# ~/.aliases

# Claude
alias claude="claude --dangerously-skip-permissions"

# Git
alias gs="git status"

# Navigation
alias ll="eza -la"
alias ..="cd .."
alias ...="cd ../.."
alias mkdir="mkdir -p"

# System
alias df="df -h"
alias du="du -h"
alias reload="source ~/.bashrc"
alias path='echo $PATH | tr -s ":" "\n"'

# Lamina
alias lm="cd ~/dev/lamina"
alias lr="lamina repo"
alias lrs="lamina repo status"
alias lt="lamina test"
alias ld="lamina deps"

# Aurelia
alias as="aurelia status"

# Docker (OrbStack)
alias d='docker'
alias dps='docker ps'
alias dpsa='docker ps -a'
alias dex='docker exec -it'
alias dlog='docker logs -f'

# Chrome with a named profile: chrome <profile> [url ...]
chrome() {
  local profile="$1"
  shift
  open -na "Google Chrome" --args --profile-directory="$profile" "$@"
}

# FortiVPN: vpn up | vpn down
vpn() {
  case "$1" in
    up)   ~/dev/forti-vpn/up.sh ;;
    down) ~/dev/forti-vpn/down.sh ;;
    *)    echo "usage: vpn up|down" >&2; return 1 ;;
  esac
}
